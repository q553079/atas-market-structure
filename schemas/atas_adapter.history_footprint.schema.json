{
  "$defs": {
    "AdapterHistoryFootprintBar": {
      "description": "One historical bar enriched with price-level footprint structure.",
      "properties": {
        "started_at": {
          "description": "Inclusive bar start timestamp.",
          "format": "date-time",
          "title": "Started At",
          "type": "string"
        },
        "ended_at": {
          "description": "Inclusive bar end timestamp.",
          "format": "date-time",
          "title": "Ended At",
          "type": "string"
        },
        "open": {
          "description": "Bar open.",
          "examples": [
            21540.25
          ],
          "title": "Open",
          "type": "number"
        },
        "high": {
          "description": "Bar high.",
          "examples": [
            21548.0
          ],
          "title": "High",
          "type": "number"
        },
        "low": {
          "description": "Bar low.",
          "examples": [
            21535.5
          ],
          "title": "Low",
          "type": "number"
        },
        "close": {
          "description": "Bar close.",
          "examples": [
            21544.75
          ],
          "title": "Close",
          "type": "number"
        },
        "volume": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional total volume.",
          "examples": [
            842
          ],
          "title": "Volume"
        },
        "delta": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional net delta.",
          "examples": [
            121
          ],
          "title": "Delta"
        },
        "bid_volume": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional bid-side traded volume.",
          "examples": [
            360
          ],
          "title": "Bid Volume"
        },
        "ask_volume": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional ask-side traded volume.",
          "examples": [
            481
          ],
          "title": "Ask Volume"
        },
        "bar_timestamp_utc": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "UTC-normalised bar timestamp preserved from ATAS metadata before timezone normalisation.",
          "title": "Bar Timestamp Utc"
        },
        "original_bar_time_text": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Raw bar time text string as it appeared in ATAS before any timezone interpretation.",
          "examples": [
            "2026-03-17 09:30:00 EST"
          ],
          "title": "Original Bar Time Text"
        },
        "price_levels": {
          "description": "Price-level footprint rows captured for this bar.",
          "items": {
            "$ref": "#/$defs/AdapterHistoryFootprintLevel"
          },
          "title": "Price Levels",
          "type": "array"
        }
      },
      "required": [
        "started_at",
        "ended_at",
        "open",
        "high",
        "low",
        "close"
      ],
      "title": "AdapterHistoryFootprintBar",
      "type": "object"
    },
    "AdapterHistoryFootprintLevel": {
      "description": "One historical footprint price level exported from an ATAS candle.",
      "properties": {
        "price": {
          "description": "Price level.",
          "examples": [
            21544.75
          ],
          "title": "Price",
          "type": "number"
        },
        "bid_volume": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Bid-side traded volume at this price.",
          "examples": [
            24
          ],
          "title": "Bid Volume"
        },
        "ask_volume": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Ask-side traded volume at this price.",
          "examples": [
            37
          ],
          "title": "Ask Volume"
        },
        "total_volume": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Total traded volume at this price.",
          "examples": [
            61
          ],
          "title": "Total Volume"
        },
        "delta": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Net delta at this price.",
          "examples": [
            13
          ],
          "title": "Delta"
        },
        "trade_count": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional trade count or ticks at this price.",
          "examples": [
            9
          ],
          "title": "Trade Count"
        }
      },
      "required": [
        "price"
      ],
      "title": "AdapterHistoryFootprintLevel",
      "type": "object"
    },
    "AdapterTimeContext": {
      "description": "Time-zone metadata describing how ATAS timestamps were interpreted.",
      "properties": {
        "instrument_timezone_value": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Raw instrument timezone value from ATAS metadata.",
          "title": "Instrument Timezone Value"
        },
        "instrument_timezone_source": {
          "default": "unavailable",
          "description": "Where the instrument timezone came from.",
          "title": "Instrument Timezone Source",
          "type": "string"
        },
        "chart_display_timezone_mode": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "ATAS chart display timezone mode when known.",
          "title": "Chart Display Timezone Mode"
        },
        "chart_display_timezone_source": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Where the chart display timezone mode came from.",
          "title": "Chart Display Timezone Source"
        },
        "chart_display_timezone_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Resolved chart display timezone name or abbreviation.",
          "title": "Chart Display Timezone Name"
        },
        "chart_display_utc_offset_minutes": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Resolved chart display UTC offset in minutes.",
          "title": "Chart Display Utc Offset Minutes"
        },
        "timezone_capture_confidence": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Confidence level of the timezone capture: high, medium, low, or unknown.",
          "title": "Timezone Capture Confidence"
        },
        "collector_local_timezone_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Collector machine local timezone name.",
          "title": "Collector Local Timezone Name"
        },
        "collector_local_utc_offset_minutes": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Collector machine local UTC offset in minutes.",
          "title": "Collector Local Utc Offset Minutes"
        },
        "timestamp_basis": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Primary basis used to normalize timestamps to UTC.",
          "title": "Timestamp Basis"
        },
        "started_at_output_timezone": {
          "default": "UTC",
          "description": "Timezone used for started_at-style output fields.",
          "title": "Started At Output Timezone",
          "type": "string"
        },
        "started_at_time_source": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Source used to resolve started_at timestamps.",
          "title": "Started At Time Source"
        }
      },
      "title": "AdapterTimeContext",
      "type": "object"
    },
    "InstrumentRef": {
      "description": "Stable instrument metadata for replay and backtests.",
      "properties": {
        "symbol": {
          "description": "Trading symbol.",
          "examples": [
            "NQH6"
          ],
          "title": "Symbol",
          "type": "string"
        },
        "root_symbol": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Root or continuous symbol when known.",
          "examples": [
            "NQ"
          ],
          "title": "Root Symbol"
        },
        "contract_symbol": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Resolved contract symbol when known.",
          "examples": [
            "NQH6"
          ],
          "title": "Contract Symbol"
        },
        "venue": {
          "description": "Execution or quote venue.",
          "examples": [
            "CME"
          ],
          "title": "Venue",
          "type": "string"
        },
        "tick_size": {
          "description": "Minimum price increment. A value of 0 means the collector could not resolve tick size and the payload is degraded.",
          "examples": [
            0.25
          ],
          "minimum": 0,
          "title": "Tick Size",
          "type": "number"
        },
        "currency": {
          "description": "PnL currency.",
          "examples": [
            "USD"
          ],
          "title": "Currency",
          "type": "string"
        }
      },
      "required": [
        "symbol",
        "venue",
        "tick_size",
        "currency"
      ],
      "title": "InstrumentRef",
      "type": "object"
    },
    "SourceRef": {
      "description": "Producer metadata for tracing and support.",
      "properties": {
        "system": {
          "description": "Source system name.",
          "examples": [
            "ATAS"
          ],
          "title": "System",
          "type": "string"
        },
        "instance_id": {
          "description": "Producer instance identifier.",
          "examples": [
            "DESKTOP-ATAS-01"
          ],
          "title": "Instance Id",
          "type": "string"
        },
        "chart_instance_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Chart or indicator-instance identifier used to separate multiple live ATAS charts.",
          "examples": [
            "NQM6-7fa31b2c"
          ],
          "title": "Chart Instance Id"
        },
        "adapter_version": {
          "description": "Source adapter version.",
          "examples": [
            "0.1.0"
          ],
          "title": "Adapter Version",
          "type": "string"
        },
        "chart_display_timezone_mode": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "ATAS chart display timezone mode captured at payload emission.",
          "examples": [
            "exchange",
            "local",
            "exchange_dst"
          ],
          "title": "Chart Display Timezone Mode"
        },
        "chart_display_timezone_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "ATAS chart display timezone name or abbreviation captured at payload emission.",
          "examples": [
            "America/New_York",
            "EST5EDT",
            "UTC"
          ],
          "title": "Chart Display Timezone Name"
        },
        "chart_display_utc_offset_minutes": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "ATAS chart display UTC offset in minutes captured at payload emission.",
          "examples": [
            -300
          ],
          "title": "Chart Display Utc Offset Minutes"
        },
        "instrument_timezone_value": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Raw instrument timezone value from ATAS metadata captured at payload emission.",
          "title": "Instrument Timezone Value"
        },
        "instrument_timezone_source": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Where the instrument timezone came from, captured at payload emission.",
          "examples": [
            "exchange_profile",
            "symbol_suffix"
          ],
          "title": "Instrument Timezone Source"
        },
        "collector_local_timezone_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Collector machine local timezone name at payload emission.",
          "examples": [
            "America/New_York"
          ],
          "title": "Collector Local Timezone Name"
        },
        "collector_local_utc_offset_minutes": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Collector machine local UTC offset in minutes at payload emission.",
          "examples": [
            -300
          ],
          "title": "Collector Local Utc Offset Minutes"
        },
        "timestamp_basis": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Primary basis used to normalize timestamps to UTC at payload emission.",
          "examples": [
            "exchange_tick_time",
            "collector_local_time",
            "chart_display_time"
          ],
          "title": "Timestamp Basis"
        },
        "timezone_capture_confidence": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Confidence level of the timezone capture at payload emission: high, medium, low, or unknown.",
          "examples": [
            "high",
            "medium",
            "low",
            "unknown"
          ],
          "title": "Timezone Capture Confidence"
        }
      },
      "required": [
        "system",
        "instance_id",
        "adapter_version"
      ],
      "title": "SourceRef",
      "type": "object"
    },
    "Timeframe": {
      "enum": [
        "1mo",
        "1w",
        "1d",
        "3d",
        "1h",
        "4h",
        "30m",
        "15m",
        "5m",
        "1m",
        "footprint",
        "dom"
      ],
      "title": "Timeframe",
      "type": "string"
    }
  },
  "description": "Chunked chart-loaded historical footprint exported from the active ATAS chart.",
  "properties": {
    "schema_version": {
      "description": "Payload schema version.",
      "examples": [
        "1.0.0"
      ],
      "title": "Schema Version",
      "type": "string"
    },
    "message_id": {
      "description": "Unique adapter message identifier.",
      "examples": [
        "adapter-msg-20260316-143001"
      ],
      "title": "Message Id",
      "type": "string"
    },
    "emitted_at": {
      "description": "When the adapter emitted this message.",
      "format": "date-time",
      "title": "Emitted At",
      "type": "string"
    },
    "observed_window_start": {
      "description": "Inclusive start of the observed window.",
      "format": "date-time",
      "title": "Observed Window Start",
      "type": "string"
    },
    "observed_window_end": {
      "description": "Inclusive end of the observed window.",
      "format": "date-time",
      "title": "Observed Window End",
      "type": "string"
    },
    "source": {
      "$ref": "#/$defs/SourceRef",
      "description": "Source metadata."
    },
    "instrument": {
      "$ref": "#/$defs/InstrumentRef",
      "description": "Instrument metadata."
    },
    "display_timeframe": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Display/native chart timeframe when known.",
      "title": "Display Timeframe"
    },
    "time_context": {
      "anyOf": [
        {
          "$ref": "#/$defs/AdapterTimeContext"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Timezone-resolution metadata for this payload."
    },
    "message_type": {
      "const": "history_footprint",
      "description": "Adapter message family for chart-loaded historical footprint chunks.",
      "title": "Message Type",
      "type": "string"
    },
    "batch_id": {
      "description": "Stable batch identifier grouping all chunks for one historical footprint export.",
      "examples": [
        "footprint-batch-nq-20260317T091500Z"
      ],
      "title": "Batch Id",
      "type": "string"
    },
    "bar_timeframe": {
      "$ref": "#/$defs/Timeframe",
      "description": "Native timeframe of the exported chart bars."
    },
    "chunk_index": {
      "description": "Zero-based chunk index.",
      "minimum": 0,
      "title": "Chunk Index",
      "type": "integer"
    },
    "chunk_count": {
      "description": "Total chunk count in this batch.",
      "minimum": 1,
      "title": "Chunk Count",
      "type": "integer"
    },
    "bars": {
      "description": "Historical footprint bars for this chunk.",
      "items": {
        "$ref": "#/$defs/AdapterHistoryFootprintBar"
      },
      "title": "Bars",
      "type": "array"
    }
  },
  "required": [
    "schema_version",
    "message_id",
    "emitted_at",
    "observed_window_start",
    "observed_window_end",
    "source",
    "instrument",
    "message_type",
    "batch_id",
    "bar_timeframe",
    "chunk_index",
    "chunk_count"
  ],
  "title": "AdapterHistoryFootprintPayload",
  "type": "object"
}
